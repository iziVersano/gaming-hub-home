# Telegram Agent Configuration
# Copy this to .env.telegram and fill in your values.
# NEVER commit .env.telegram to git.

# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram user ID (get it from @userinfobot)
# Comma-separated list of allowed chat IDs
TELEGRAM_ALLOWED_IDS=123456789

# How often to poll for new messages (milliseconds)
TELEGRAM_POLL_INTERVAL=5000
