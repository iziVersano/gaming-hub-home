  "framework": "nest",
  "outputDirectory": "dist",
  "env": {
    "NODE_ENV": "production",
    "PORT": "3000"
  },
  "public": false,
  "regions": ["fra1"],
  "functions": {
    "dist/main.js": {
      "memory": 1024,
      "maxDuration": 300,
      "runtime": "nodejs20.x"
    }
  }
}
